---
layout: default
prototype:
  term: tag
  collection: posts
pagination:
  collection: posts
  per_page: 12
---
<h1>Articles tagged '<%= data.tag %>'</h1>

<% if paginator.total_pages > 1 %>
  <p>Page <%= paginator.page %> of <%= paginator.total_pages %></p>

  <% if paginator.previous_page %>
    <p><a href="<%= paginator.previous_page_path %>">Previous page</a></p>
  <% end %>
<% end %>

<ul>
  <% paginator.resources.each do |article| %>
    <li>
      <a href="<%= article.relative_url %>"><%= article.data.title %></a>
      <span><%= article.data.date.strftime('%b %d, %Y') %></span>
    </li>
  <% end %>
</ul>

<% if paginator.next_page %>
  <p><a href="<%= paginator.next_page_path %>">Next page</a></p>
<% end %>
